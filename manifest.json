{
  "manifest_version": 3,
  "name": "Smart Tab Pinner",
  "version": "1.0.0",
  "author": "去年夏天",
  "description": "定期检查指定标签页是否被打开",
  "permissions": ["tabs", "storage", "alarms"],
  "background": {
    "service_worker": "background.js", 
    "type": "module"
  },
  "action": {
    "default_icon": {
      "128": "icon.png"
    },
    "default_title": "打开设置页"
  },
  "options_ui": {
    "page": "settings/index.html",
    "open_in_tab": true // 关键：在独立标签页打开设置页
  },
  "icons": {
    "128": "icon.png"
  }
}