{
  "manifest_version": 3,
  "name": "Smart Tab Pinner",
  "version": "1.0.1",
  "author": "去年夏天",
  "description": "定期检测并自动打开或固定指定标签页。支持通配符模糊匹配，支持前后台灵活唤醒，防止重要网页被误关闭。",
  "permissions": ["tabs", "storage", "alarms"],
  "background": {
    "service_worker": "background.js", 
    "type": "module"
  },
  "action": {
    "default_icon": {
      "128": "icon.png"
    },
    "default_title": "打开设置页"
  },
  "options_ui": {
    "page": "settings/index.html",
    "open_in_tab": true 
  },
  "icons": {
    "128": "icon.png"
  }
}